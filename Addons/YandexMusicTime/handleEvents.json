                        },
                        "3": {
                            "event": "month",
                            "name": "Прослушано за месяц"
                        },
                        "4": {
                            "event": "week",
                            "name": "Прослушано за неделю"
                        },
                        "5": {
                            "event": "day",
                            "name": "Прослушано за день"
                        },
                        "6": {
